package br.com.afya.infrastructure.repository;
 
import br.com.afya.domain.Inscricao;
import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.stereotype.Repository;
 
import java.util.List;
import java.util.Optional;
 
@Repository
public interface InscricaoRepository extends JpaRepository<Inscricao, Long> {
 
    List<Inscricao> findByParticipanteId(Long participanteId);
    List<Inscricao> findByAtividadeId(Long atividadeId);
    Optional<Inscricao> findByParticipanteIdAndAtividadeId(Long participanteId, Long atividadeId);
    boolean existsByParticipanteIdAndAtividadeId(Long participanteId, Long atividadeId);
}
